# ── Backend environment variables ───────────────────────────────────────
# Copy to `.env` for local dev, and set these in the Render dashboard for prod.

# Server
PORT=5000
NODE_ENV=production            # use "production" on Render; omit/empty locally

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ieee-tems

# JWT secret for admin auth (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin accounts
ADMIN_USER_1=Admin2026
ADMIN_PASS_1=change-me
ADMIN_USER_2=Admin2027
ADMIN_PASS_2=change-me

# ── Cloudinary (persistent image/video storage) ─────────────────────────
# Get these from the Cloudinary dashboard (cloudinary.com, free tier).
# When all three are set, uploads go to Cloudinary; otherwise local disk.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
